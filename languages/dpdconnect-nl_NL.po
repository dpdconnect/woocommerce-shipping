#: classes/OrderValidator.php
msgid ""
"Product country of origin is missing for: %1$s . Either set a country for <a "
"href=\"wp-admin/post.php?post=%2$s&action=edit\">this product</a> in its "
"shipping attributes or configure a <a href=\"/wp-admin/admin.php?"
"page=dpdconnect\">default country</a> for your entire shop."
